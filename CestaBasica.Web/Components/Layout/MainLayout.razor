@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing
@using CestaBasica.Web.Services
@inject SessaoUsuarioService Sessao
@inject NavigationManager Navigation

@if (Sessao.UsuarioLogado != null)
{
    <div class="app-layout">

    <aside class="sidebar @(menuAberto ? "" : "collapsed")">

        <div class="sidebar-header">

            <div class="logo">
                🧺
            </div>

            @if (menuAberto)
            {
                <div class="sidebar-user">
                    <strong>@Sessao.UsuarioLogado?.Nome</strong>
                    <small>@Sessao.UsuarioLogado?.Perfil</small>
                </div>
            }

        </div>

        <button class="toggle-btn" @onclick="AlternarMenu">
            ☰
        </button>

        <nav>
            <NavLink href="/dashboard" Match="NavLinkMatch.All">
                <span>📊 Dashboard</span>
            </NavLink>

            <NavLink href="/funcionarios">
                <span>👥 Funcionários</span>
            </NavLink>
            <NavLink href="/cestas">
                <span>🧺 Cesta Básica</span>
            </NavLink>
            <NavLink href="/retiradas">
                <span>📦 Retiradas</span>
            </NavLink>

            <NavLink href="/notificacoes">
                <span>🔔 Notificações</span>
            </NavLink>

            @if (Sessao.IsAdmin)
            {
                <NavLink href="/usuarios">
                    <span>👤 Usuários</span>
                </NavLink>

                <NavLink href="/configuracoes">
                    <span>⚙️ Configurações</span>
                </NavLink>
            }
            <a href="javascript:void(0)" class="nav-logout" @onclick="AbrirModalSair">
                <span>🚪 Sair</span>
            </a>
        </nav>

        
    </aside>

    <main class="page-content">
        @Body
    </main>
    @if (mostrarModalSair)
    {
        <div class="modal-logout-overlay">
            <div class="modal-logout">

                <h3>Deseja realmente sair?</h3>
                <p>Sua sessão será encerrada.</p>

                <div class="modal-actions">
                    <button class="btn-cancel" @onclick="FecharModalSair">
                        Cancelar
                    </button>

                    <button class="btn-confirm" @onclick="ConfirmarLogout">
                        Sim, sair
                    </button>
                </div>
            </div>
        </div>
    }

</div>
}
<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>


@code {
    private bool menuAberto = true;
    private bool mostrarModalSair = false;

    protected override void OnInitialized()
    {
        if (Sessao.UsuarioLogado == null)
        {
            Navigation.NavigateTo("/login", true);
        }
    }

    private void AlternarMenu()
    {
        menuAberto = !menuAberto;
    }

    private void AbrirModalSair()
    {
        mostrarModalSair = true;
    }

    private void FecharModalSair()
    {
        mostrarModalSair = false;
    }

    private void ConfirmarLogout()
    {
        Sessao.Logout();
        Navigation.NavigateTo("/login", true);
    }
}