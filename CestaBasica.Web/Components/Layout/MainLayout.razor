@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing

<div class="app-layout">

    <aside class="sidebar @(menuAberto ? "" : "collapsed")">

        <div class="sidebar-header">
            <div class="logo">🧺</div>

            @if (menuAberto)
            {
                <span>Gestão Social</span>
            }
        </div>

        <button class="toggle-btn" @onclick="AlternarMenu">
            ☰
        </button>

        <nav>
            <NavLink href="/dashboard" Match="NavLinkMatch.All">
                <span>📊 Dashboard</span>
            </NavLink>

            <NavLink href="/funcionarios">
                <span>👥 Funcionários</span>
            </NavLink>
            <NavLink href="/cestas">
                <span>🧺 Cesta Básica</span>
            </NavLink>
            <NavLink href="/retiradas">
                <span>📦 Retiradas</span>
            </NavLink>

            <NavLink href="/notificacoes">
                <span>🔔 Notificações</span>  
            </NavLink>

            <NavLink href="/usuarios">
                <span>🛡️ Usuários</span>
            </NavLink>

            <NavLink href="/configuracoes">
                <span>⚙️ Configurações</span>
            </NavLink>
        </nav>

    </aside>

    <main class="page-content">
        @Body
    </main>

</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool menuAberto = true;

    private void AlternarMenu()
    {
        menuAberto = !menuAberto;
    }
}