@page "/login"

@using CestaBasica.Web.Models.Requests
@using CestaBasica.Web.Components.Layout
@using CestaBasica.Shared.Enums
@using CestaBasica.Web.Services
@using Microsoft.AspNetCore.Components.Forms

@layout EmptyLayout

@inject UsuarioApiService UsuarioService
@inject NavigationManager Navigation


<div class="login-page">

    <div class="login-left">

        <div class="overlay"></div>

        <div class="left-content">

            <h1>
                <p>
                    Solução corporativa desenvolvida para otimizar processos,
                    ampliar a transparência operacional e garantir maior eficiência
                    na administração de programas de assistência e distribuição.
                </p>
                <span>Distribuição de Cestas Básicas</span>
            </h1>

            <p>
                Tecnologia e gestão para promover solidariedade,
                eficiência e impacto social.
            </p>

            <div class="features">

                <div class="feature-item">
                    🔒 Segurança
                </div>

                <div class="feature-item">
                    👥 Transparência
                </div>

                <div class="feature-item">
                    📈 Eficiência
                </div>

            </div>

        </div>

    </div>

    <div class="login-right">

        <div class="login-card">

            <div class="logo-area">

                <div class="logo-icon">
                    🧺
                </div>

                <h2>
                    Sistema de Apoio à Gestão de
                    Programas de Distribuição de
                    Cestas Básicas
                </h2>

            </div>

            <EditForm Model="login" OnValidSubmit="FazerLogin" FormName="loginForm">

                <div class="tipo-usuario mb-4">
                    <label class="tipo-label">Tipo de Usuário</label>

                    <InputSelect class="perfil-select" @bind-Value="login.Perfil">
                        <option value="@PerfilUsuario.Admin">🛡️ Administrador</option>
                        <option value="@PerfilUsuario.Usuario">👤 Usuário</option>
                    </InputSelect>
                </div>

                <div class="mb-4">
                    <label class="form-label">E-mail</label>
                    <InputText class="form-control input-custom" @bind-Value="login.Email" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Senha</label>
                    <InputText type="password" class="form-control input-custom" @bind-Value="login.Senha" />
                </div>

                <button type="submit" class="btn-login">
                    Entrar
                </button>

            </EditForm>

            @if (!string.IsNullOrEmpty(mensagem))
            {
                <div class="alert alert-danger mt-4">
                    @mensagem
                </div>

               
            }

            <div class="security-text">
                🔐 Ambiente seguro. Seus dados estão protegidos.
            </div>

        </div>

    </div>

</div>