@page "/funcionarios"
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web



<div class="employees-page">
    <div class="page-header">
        <div class="header-left">

            <div>
                <h1>Gerenciamento de Funcionários</h1>
                <p>Controle administrativo de beneficiários, retiradas e histórico operacional.</p>
            </div>
        </div>
        <div class="header-actions">
            <NavLink href="/funcionarios/novo" class="btn-primary">
                + Novo funcionário
            </NavLink>
            <NavLink href="/funcionarios/importacao" class="btn-primary">
                + Importar funcionários
            </NavLink>
        </div>
    </div>
    <section class="filters-card">
        <div class="search-box">
            <label>Busca rápida</label>
            <input placeholder="Pesquisar por nome, matrícula ou código de barras..." @bind="termoBusca" @bind:event="oninput" />
        </div>

        <div class="filter-group">
            <div>
                <label>Status</label>
                <select>
                    <option>Todos</option>
                    <option>Retirado</option>
                    <option>Pendente</option>
                </select>
            </div>

            <div>
                <label>Secretaria/Setor</label>
                <select>
                    <option>Todos</option>
                    <option>Assistência Social</option>
                    <option>Educação</option>
                    <option>Saúde</option>
                    <option>Administração</option>
                </select>
            </div>

            <div>
                <label>Data inicial</label>
                <input type="date" />
            </div>

            <div>
                <label>Data final</label>
                <input type="date" />
            </div>
        </div>
    </section>

    <section class="table-card">
        <div class="table-header">
            <div>
                <h2>Funcionários cadastrados</h2>
                <span>
                    Total encontrado: <strong>@TotalFuncionarios</strong> funcionário(s)
                </span>
            </div>

            <button class="btn-secondary">Exportar</button>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Matrícula</th>
                        <th>Código de barras</th>
                        <th>Telefone</th>
                        <th>Secretaria/Setor</th>
                        <th>Status de retirada</th>
                        <th>Ações</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var funcionario in FuncionariosFiltrados)
                    {
                        <tr>
                            <td>
                                <div class="employee-info">
                                    <strong>@funcionario.Nome</strong>
                                    <small>@funcionario.Email</small>
                                </div>
                            </td>
                            <td>@funcionario.Matricula</td>
                            <td>@funcionario.CodigoBarras</td>
                            <td>@funcionario.Telefone</td>
                            <td>@funcionario.Setor</td>
                            <td>
                                <span class="badge @(funcionario.Status == "Retirado" ? "success" : "warning")">
                                    @funcionario.Status
                                </span>
                            </td>
                            <td>
                                <div class="actions">

                                    <button type="button" title="Editar" @onclick="() => EditarFuncionario(funcionario.Id)">
                                        ✏️
                                    </button>

                                    <button type="button" title="Excluir"
                                            @onclick="() => ExcluirFuncionario(funcionario.Id)">
                                        🗑️
                                    </button>

                                    <button type="button" title="Visualizar histórico"
                                            @onclick="() => VisualizarHistorico(funcionario.Id)">
                                        📄
                                    </button>

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination">
            <span>Exibindo 1-5 de 128 registros</span>

            <div>
                <button>Anterior</button>
                <button class="active">1</button>
                <button>2</button>
                <button>3</button>
                <button>Próxima</button>
            </div>
        </div>
    </section>
</div>