@page "/funcionarios"
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web

<div class="employees-page">
    <div class="page-header">
        <div class="header-left">

            <div>
                <h1>Gerenciamento de Funcionários</h1>
                <p>Controle administrativo de beneficiários, retiradas e histórico operacional.</p>
            </div>
        </div>
        <div class="header-actions">
            <NavLink href="/novo" class="btn-primary">
                + Novo funcionário
            </NavLink>
            <NavLink href="/importacao" class="btn-primary">
                + Importar funcionários
            </NavLink>
        </div>
    </div>
    <section class="filters-card">
        <div class="search-box">
            <label>Busca rápida</label>
            <input placeholder="Pesquisar por nome, matrícula ou código de barras..." @bind="termoBusca"
                   @bind:event="oninput" />
        </div>

        <div class="filter-group">
            <div>
                <label>Status</label>
                <select>
                    <option>Todos</option>
                    <option>Retirado</option>
                    <option>Pendente</option>
                </select>
            </div>

            <div>
                <label>Secretaria/Setor</label>
                <select>
                    <option>Todos</option>
                    <option>Assistência Social</option>
                    <option>Educação</option>
                    <option>Saúde</option>
                    <option>Administração</option>
                </select>
            </div>

            <div>
                <label>Data inicial</label>
                <input type="date" />
            </div>

            <div>
                <label>Data final</label>
                <input type="date" />
            </div>
        </div>
    </section>

    <section class="table-card">
        <div class="table-header">
            <div>
                <h2>Funcionários cadastrados</h2>
                <span>
                    Total encontrado: <strong>@TotalFuncionarios</strong> funcionário(s)
                </span>
            </div>

            <button class="btn-secondary">Exportar</button>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Matrícula</th>
                        <th>Código de barras</th>
                        <th>Telefone</th>
                        <th>Secretaria/Setor</th>
                        <th>Status de retirada</th>
                        <th>Ações</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var funcionario in FuncionariosPaginados)
                    {
                        <tr class="@(EditarFuncionarioId == funcionario.Id ? "editing-row" : "")">
                            <td>
                                @if (EditarFuncionarioId == funcionario.Id)
                                {
                                    <input class="table-input" @bind="funcionario.Nome" />
                                }
                                else
                                {
                                    <div class="employee-info">
                                        <strong>@funcionario.Nome</strong>
                                    </div>
                                }
                            </td>

                            <td>
                                @if (EditarFuncionarioId == funcionario.Id)
                                {
                                    <input class="table-input" @bind="funcionario.Matricula" />
                                }
                                else
                                {
                                    @funcionario.Matricula
                                }
                            </td>

                            <td>
                                @if (EditarFuncionarioId == funcionario.Id)
                                {
                                    <input class="table-input" @bind="funcionario.CodigoBarras" />
                                }
                                else
                                {
                                    @funcionario.CodigoBarras
                                }
                            </td>

                            <td>
                                @if (EditarFuncionarioId == funcionario.Id)
                                {
                                    <input class="table-input" @bind="funcionario.Telefone" />
                                }
                                else
                                {
                                    @funcionario.Telefone
                                }
                            </td>

                            <td>
                                @if (EditarFuncionarioId == funcionario.Id)
                                {
                                    <input class="table-input" @bind="funcionario.Setor" />
                                }
                                else
                                {
                                    @funcionario.Setor
                                }
                            </td>

                            <td>
                                <span class="badge @(funcionario.Status == "Retirado" ? "success" : "warning")">
                                    @funcionario.Status
                                </span>
                            </td>

                            <td>
                                <div class="actions">
                                    @if (EditarFuncionarioId == funcionario.Id)
                                    {
                                        <button type="button" title="Salvar" @onclick="() => SalvarFuncionario(funcionario)">
                                            💾
                                        </button>

                                        <button type="button" title="Cancelar" @onclick="CancelarEdicao">
                                            ❌
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" title="Editar"
                                                @onclick="() => EditarFuncionarioId = funcionario.Id">
                                            ✏️
                                        </button>

                                        <button type="button" title="Excluir"
                                                @onclick="() => ExcluirFuncionario(funcionario.Id)">
                                            🗑️
                                        </button>

                                        <button type="button" title="Visualizar histórico"
                                                @onclick="() => VisualizarHistorico(funcionario)">
                                            📄
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination">
            <span>
                Página @PaginaAtual de @TotalPaginas —
                Total: <strong>@TotalFuncionarios</strong> registros
            </span>

            <div>
                <button disabled="@(PaginaAtual == 1)" @onclick="PaginaAnterior">
                    Anterior
                </button>

                @for (var i = 1; i <= TotalPaginas; i++)
                {
                    var pagina = i;

                    <button class="@(PaginaAtual == pagina ? "active" : "")" @onclick="() => IrParaPagina(pagina)">
                        @pagina
                    </button>
                }

                <button disabled="@(PaginaAtual == TotalPaginas)" @onclick="ProximaPagina">
                    Próxima
                </button>
            </div>
        </div>
    </section>
    @if (MostrarHistorico && FuncionarioHistorico is not null)
    {
        <div class="modal-overlay">
            <div class="modal-card">
                <div class="modal-header">
                    <h3>Histórico de retirada</h3>
                    <button type="button" @onclick="FecharHistorico">✖</button>
                </div>

                <p><strong>Funcionário:</strong> @FuncionarioHistorico.Nome</p>
                <p><strong>Status:</strong> @FuncionarioHistorico.Status</p>

                <div class="history-box">
                    <p>📦 Última retirada: informação da API aqui</p>
                    <p>📅 Próxima retirada: informação da API aqui</p>
                </div>
            </div>
        </div>
    }
</div>