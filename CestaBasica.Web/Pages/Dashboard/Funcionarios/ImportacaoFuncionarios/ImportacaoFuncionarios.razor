@page "/importacao"
@namespace CestaBasica.Web.Pages.Dashboard.Funcionarios.ImportacaoFuncionarios
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Routing
@using CestaBasica.Shared.DTOs

<div class="import-page">

    <div class="page-header">
        <div>
            <h1>Importação de Planilhas</h1>
            <p>Carregue arquivos Excel ou CSV para cadastro e atualização de registros no sistema.</p>
        </div>
    </div>

    <section class="upload-card">
        <div class="upload-area">

            <div style="@(arquivoSelecionado is null ? "" : "display:none")">
                <div class="upload-icon">📄</div>
                <h2>Arraste e solte sua planilha aqui</h2>
                <p>Formatos aceitos: Excel (.xlsx, .xls) e CSV (.csv)</p>
                <label class="btn-upload">
                    Selecionar arquivo
                    <InputFile OnChange="SelecionarArquivo" accept=".xlsx,.xls,.csv" />
                </label>
            </div>

            <div style="@(arquivoSelecionado is not null ? "" : "display:none")">
                <div class="upload-icon">✅</div>
                <h2>Arquivo pronto para importação</h2>
                <div class="file-selected-box">
                    <span class="file-icon">📊</span>
                    <div>
                        <strong>@nomeArquivo</strong>
                        <p>Clique em "Importar registros válidos" para processar</p>
                    </div>
                    <button class="btn-remove" @onclick="RemoverArquivo">✕</button>
                </div>
            </div>

        </div>
    </section>

    <section class="summary-grid">
        <div class="summary-card success">
            <span>Registros válidos</span>
            <h2>@validos</h2>
        </div>
        <div class="summary-card danger">
            <span>Registros inválidos</span>
            <h2>@invalidos</h2>
        </div>
        <div class="summary-card neutral">
            <span>Total analisado</span>
            <h2>@total</h2>
        </div>
    </section>

    <section class="preview-card">
        <div class="card-header">
            <div>
                <h2>Pré-visualização da planilha</h2>
                <span>Validação automática dos dados antes da importação.</span>
            </div>
            <button class="btn-primary" @onclick="ImportarRegistrosValidos" disabled="@importando">
                @(importando ? "Importando..." : "Importar registros válidos")
            </button>
        </div>

        @if (progresso > 0)
        {
            <div class="progress-area">
                <div class="progress-info">
                    <span>Importando registros...</span>
                    <strong>@progresso%</strong>
                </div>
                <div class="progress-bar">
                    <div style="width:@progresso%"></div>
                </div>
            </div>
        }

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Linha</th>
                        <th>Nome</th>
                        <th>Matrícula</th>
                        <th>Código de barras</th>
                        <th>Telefone</th>
                        <th>Setor</th>
                        <th>Status</th>
                        <th>Erros</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!registros.Any())
                    {
                        <tr>
                            <td colspan="8" class="table-empty">
                                Nenhum arquivo carregado ainda.
                            </td>
                        </tr>
                    }
                    @foreach (RegistroImportacaoDto item in registros)
                    {
                        <tr class="@(item.Valido ? "" : "invalid-row")">
                            <td>@item.Linha</td>
                            <td>@item.Nome</td>
                            <td>@item.Matricula</td>
                            <td>@item.CodigoBarras</td>
                            <td>@item.Telefone</td>
                            <td>@item.Setor</td>
                            <td>
                                <span class="badge @(item.Valido ? "success" : "danger")">
                                    @(item.Valido ? "Válido" : "Inválido")
                                </span>
                            </td>
                            <td>@item.Erro</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="history-card">
        <div class="card-header">
            <div>
                <h2>Histórico de importações recentes</h2>
                <span>Controle das últimas operações realizadas.</span>
            </div>
        </div>
        <div class="history-list">
            @foreach (var item in historico)
            {
                <div class="history-item">
                    <div>
                        <strong>@item.NomeArquivo</strong>
                        <p>@item.DataImportacao.ToString("dd/MM/yyyy HH:mm") - @item.Usuario</p>
                    </div>
                    <span>@item.QuantidadeRegistros registros</span>
                </div>
            }
        </div>
    </section>

</div>