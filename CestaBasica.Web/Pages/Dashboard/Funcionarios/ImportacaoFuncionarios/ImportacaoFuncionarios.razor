@page "/importacao"
@using Microsoft.AspNetCore.Components.Forms

<div class="import-page">

    <div class="page-header">
        <div>
            <h1>Importação de Planilhas</h1>
            <p>Carregue arquivos Excel ou CSV para cadastro e atualização de registros no sistema.</p>
        </div>

        <button class="btn-secondary">Gerar relatório</button>
    </div>

    <section class="upload-card">
        <div class="upload-area">
            <div class="upload-icon">📄</div>

            <h2>Arraste e solte sua planilha aqui</h2>
            <p>Formatos aceitos: Excel (.xlsx, .xls) e CSV (.csv)</p>

            <label class="btn-upload">
                Selecionar arquivo
                <InputFile OnChange="SelecionarArquivo" accept=".xlsx,.xls,.csv" />
            </label>

            @if (!string.IsNullOrEmpty(nomeArquivo))
            {
                <div class="file-selected">
                    Arquivo selecionado: <strong>@nomeArquivo</strong>
                </div>
            }
        </div>
    </section>

    <section class="summary-grid">
        <div class="summary-card success">
            <span>Registros válidos</span>
            <h2>@validos</h2>
        </div>

        <div class="summary-card danger">
            <span>Registros inválidos</span>
            <h2>@invalidos</h2>
        </div>

        <div class="summary-card neutral">
            <span>Total analisado</span>
            <h2>@total</h2>
        </div>
    </section>

    <section class="preview-card">
        <div class="card-header">
            <div>
                <h2>Pré-visualização da planilha</h2>
                <span>Validação automática dos dados antes da importação.</span>
            </div>

            <button class="btn-primary" @onclick="ImportarRegistrosValidos">
                Importar registros válidos
            </button>
        </div>

        @if (progresso > 0)
        {
            <div class="progress-area">
                <div class="progress-info">
                    <span>Importando registros...</span>
                    <strong>@progresso%</strong>
                </div>

                <div class="progress-bar">
                    <div style="width:@progresso%"></div>
                </div>
            </div>
        }

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Linha</th>
                        <th>Nome</th>
                        <th>Matrícula</th>
                        <th>Código de barras</th>
                        <th>Telefone</th>
                        <th>Setor</th>
                        <th>Status</th>
                        <th>Erros</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in registros)
                    {
                        <tr class="@(item.Valido ? "" : "invalid-row")">
                            <td>@item.Linha</td>
                            <td>@item.Nome</td>
                            <td>@item.Matricula</td>
                            <td>@item.CodigoBarras</td>
                            <td>@item.Telefone</td>
                            <td>@item.Setor</td>
                            <td>
                                <span class="badge @(item.Valido ? "success" : "danger")">
                                    @(item.Valido ? "Válido" : "Inválido")
                                </span>
                            </td>
                            <td>@item.Erro</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="history-card">
        <div class="card-header">
            <div>
                <h2>Histórico de importações recentes</h2>
                <span>Controle das últimas operações realizadas.</span>
            </div>
        </div>

        <div class="history-list">
            @foreach (var item in historico)
            {
                <div class="history-item">
                    <div>
                        <strong>@item.Arquivo</strong>
                        <p>@item.Data - @item.Usuario</p>
                    </div>

                    <span>@item.Registros registros</span>
                </div>
            }
        </div>
    </section>

</div>

@code {
    private string nomeArquivo = "";
    private int progresso = 0;

    private List<RegistroImportacao> registros = new()
    {
        new(2, "Maria Oliveira", "MAT-001", "789456123001", "(15) 99999-1001", "Educação", true, "-"),
        new(3, "João Santos", "", "789456123002", "(15) 99999-1002", "Saúde", false, "Matrícula obrigatória"),
        new(4, "Ana Lima", "MAT-003", "789456123003", "(15) 99999-1003", "Assistência Social", true, "-"),
        new(5, "", "MAT-004", "789456123004", "(15) 99999-1004", "Administração", false, "Nome obrigatório")
    };

    private List<HistoricoImportacao> historico = new()
    {
        new("funcionarios_maio.xlsx", "16/05/2026 09:30", "Administrador", 124),
        new("atualizacao_setores.csv", "15/05/2026 14:10", "Operador", 86),
        new("base_funcionarios.xlsx", "14/05/2026 10:45", "Administrador", 210)
    };

    private int validos => registros.Count(x => x.Valido);
    private int invalidos => registros.Count(x => !x.Valido);
    private int total => registros.Count;

    private void SelecionarArquivo(InputFileChangeEventArgs e)
    {
        nomeArquivo = e.File.Name;
        progresso = 0;
    }

    private async Task ImportarRegistrosValidos()
    {
        progresso = 0;

        for (int i = 0; i <= 100; i += 20)
        {
            progresso = i;
            await Task.Delay(250);
        }
    }

    public record RegistroImportacao(
        int Linha,
        string Nome,
        string Matricula,
        string CodigoBarras,
        string Telefone,
        string Setor,
        bool Valido,
        string Erro
    );

    public record HistoricoImportacao(
        string Arquivo,
        string Data,
        string Usuario,
        int Registros
    );
}