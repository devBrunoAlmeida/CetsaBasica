@page "/funcionarios/{Id:int}/historico"
@using Microsoft.AspNetCore.Components.Web

<div class="history-page">

    <div class="page-header">
        <div>
            <h1>Histórico Completo do Funcionário</h1>
            <p>Consulta consolidada de dados pessoais, notificações, retiradas e eventos registrados.</p>
        </div>

        <button class="btn-secondary" @onclick="Voltar">
            Voltar
        </button>
    </div>

    @if (Funcionario is null)
    {
        <p>Carregando histórico...</p>
    }
    else
    {
        <section class="employee-card">
            <div class="avatar">@ObterIniciais(Funcionario.NomeCompleto)</div>

            <div class="employee-data">
                <h2>@Funcionario.NomeCompleto</h2>
                <p>@Funcionario.Setor</p>

                <div class="data-grid">
                    <div>
                        <span>Matrícula</span>
                        <strong>@Funcionario.Matricula</strong>
                    </div>

                    <div>
                        <span>Código de barras</span>
                        <strong>@Funcionario.CodigoBarras</strong>
                    </div>

                    <div>
                        <span>Telefone</span>
                        <strong>@Funcionario.Telefone</strong>
                    </div>

                    <div>
                        <span>Status atual</span>
                        <strong class="status-ok">@HistoricoFuncionario?.Status</strong>
                    </div>
                </div>
            </div>
        </section>

        <section class="content-grid">

            <div class="panel">
                <div class="panel-header">
                    <h2>Histórico de Retiradas</h2>
                    <span>Registros de entregas realizadas.</span>
                </div>

                @if (!Retiradas.Any())
                {
                    <p>Nenhuma retirada registrada.</p>
                }
                else
                {
                    <table>
                        <thead>
                            <tr>
                                <th>Data/Hora</th>
                                <th>Responsável</th>
                                <th>Status</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Retiradas)
                            {
                                <tr>
                                    <td>@item.DataHora.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@item.Responsavel</td>
                                    <td><span class="badge success">@item.Titulo</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            <div class="panel">
                <div class="panel-header">
                    <h2>Histórico de Notificações</h2>
                    <span>Comunicações enviadas ao funcionário.</span>
                </div>

                @if (!Notificacoes.Any())
                {
                    <p>Nenhuma notificação registrada.</p>
                }
                else
                {
                    <table>
                        <thead>
                            <tr>
                                <th>Data/Hora</th>
                                <th>Canal</th>
                                <th>Status</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Notificacoes)
                            {
                                <tr>
                                    <td>@item.DataHora.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@item.Descricao</td>
                                    <td><span class="badge delivered">@item.Titulo</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

        </section>

        <section class="timeline-panel">
            <div class="panel-header">
                <h2>Linha do Tempo de Eventos</h2>
                <span>Sequência cronológica das ações vinculadas ao funcionário.</span>
            </div>

            @if (!Eventos.Any())
            {
                <p>Nenhum evento registrado.</p>
            }
            else
            {
                <div class="timeline">
                    @foreach (var item in Eventos)
                    {
                        <div class="timeline-item @ObterClasseTimeline(item.Tipo)">
                            <div class="dot"></div>

                            <div class="timeline-content">
                                <strong>@item.Titulo</strong>
                                <p>@item.Descricao</p>
                                <span>@item.DataHora.ToString("dd/MM/yyyy 'às' HH:mm")</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    }

</div>