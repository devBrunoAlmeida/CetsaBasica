@page "/novo"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components

@using CestaBasica.Shared.DTOs


<div class="employee-form-page">
    <div class="page-header">
        <div>
            <h1>Cadastro de Funcionário</h1>
            <p>Preencha os dados cadastrais para registrar um novo funcionário no sistema.</p>
        </div>

        <button type="button" class="btn-cancel" @onclick="Cancelar">
            ← Voltar
        </button>
    </div>

    <EditForm Model="funcionario" OnValidSubmit="Salvar" FormName="funcionarioForm">

        <DataAnnotationsValidator />
        <ValidationSummary />

        <section class="form-card">
            <div class="card-header">
                <h2>Dados do funcionário</h2>
                <span>Informações principais para identificação e controle.</span>
            </div>

            <div class="form-grid">
                <div class="form-group full">
                    <label for="nome">👤 Nome completo</label>
                    <InputText id="nome" class="form-control-custom" @bind-Value="funcionario.NomeCompleto"
                               placeholder="Digite o nome completo" autocomplete="name" />
                    <ValidationMessage For="@(() => funcionario.NomeCompleto)" />
                </div>

                <div class="form-group">
                    <label for="matricula">🆔 Matrícula</label>
                    <InputText id="matricula" class="form-control-custom" @bind-Value="funcionario.Matricula"
                               placeholder="Ex: MAT-0001" />
                    <ValidationMessage For="@(() => funcionario.Matricula)" />
                </div>

                <div class="form-group">
                    <label for="codigoBarras">📦 Código de barras</label>
                    <InputText id="codigoBarras" class="form-control-custom" @bind-Value="funcionario.CodigoBarras"
                               placeholder="Digite o código de barras" />
                    <ValidationMessage For="@(() => funcionario.CodigoBarras)" />
                </div>

                <div class="form-group">
                    <label for="telefone">📱 Telefone</label>
                    <InputText id="telefone" class="form-control-custom" @bind-Value="funcionario.Telefone"
                               maxlength="15" placeholder="(15) 99999-9999" autocomplete="tel" />
                </div>

                <div class="form-group">
                    <label for="setor">🏢 Secretaria/Setor</label>
                    <InputSelect id="setor" class="form-control-custom" @bind-Value="funcionario.Setor">
                        <option value="">Selecione o setor</option>
                        <option value="Administração">Administração</option>
                        <option value="Assistência Social">Assistência Social</option>
                        <option value="Educação">Educação</option>
                        <option value="Saúde">Saúde</option>
                        <option value="Obras e Serviços">Obras e Serviços</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => funcionario.Setor)" />
                </div>
            </div>

            <div class="form-actions">
                <button type="button" class="btn-outline" @onclick="Cancelar">
                    Cancelar
                </button>

                <button type="submit" class="btn-save">
                    💾 Salvar cadastro
                </button>
            </div>
        </section>
    </EditForm>
</div>