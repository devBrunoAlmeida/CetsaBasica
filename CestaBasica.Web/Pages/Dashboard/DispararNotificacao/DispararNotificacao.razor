@page "/notificacoes"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components

<div class="notifications-page">
    <div class="page-header">
        <div>
            <h1>Envio de Notificações</h1>
            <p>Comunique funcionários por WhatsApp.</p>
        </div>
    </div>

    <section class="content-grid">
        <div class="panel">
            <div class="panel-header">
                <h2>Destinatários</h2>
                <span>Selecione funcionários.</span>
            </div>

            <div class="selection-actions">
                <button @onclick="SelecionarTodos">Selecionar todos</button>
                <button @onclick="LimparSelecao">Limpar seleção</button>
            </div>

            <div class="employee-list">
                @foreach (var funcionario in FuncionariosPaginados)
                {
                    <label class="employee-item">
                        <input type="checkbox" @bind="funcionario.Selecionado" />

                        <div>
                            <strong> @funcionario.NomeCompleto</strong>
                            <span> @funcionario.Setor • @funcionario.Telefone</span>
                        </div>
                    </label>

                }
            </div>
            @if (TotalPaginas > 1)
            {
                <div class="pagination">
                    <button type="button" @onclick="PaginaAnterior" disabled="@(PaginaAtual == 1)">
                        Anterior
                    </button>

                    <span>Página @PaginaAtual de @TotalPaginas</span>

                    <button type="button" @onclick="ProximaPagina" disabled="@(PaginaAtual >= TotalPaginas)">
                        Próxima
                    </button>
                </div>
            }
        </div>

        <div class="panel">
            <div class="panel-header">
                <h2>Mensagem</h2>
                <span>Personalize antes do envio.</span>
            </div>

            <div class="form-group">
                <label>Canal de envio</label>

                <div class="channel-options">
                    <button type="button" class="active">WhatsApp</button>
                </div>
            </div>

            <div class="form-group">
                <label>Mensagem personalizada</label>

                <textarea @bind="Mensagem" maxlength="300" placeholder="Digite a mensagem..."></textarea>

                <small>@Mensagem.Length/300 caracteres</small>
            </div>

            <div class="preview-box">
                <span>Pré-visualização</span>
                <p>@Mensagem</p>
                <strong>Canal: WhatsApp</strong>
            </div>

            <button class="btn-primary" @onclick="EnviarNotificacao">
                Enviar notificação
            </button>

            @if (!string.IsNullOrWhiteSpace(MensagemRetorno))
            {
                <p class="retorno">@MensagemRetorno</p>
            }
        </div>
    </section>

    <section class="history-panel">
        <div class="panel-header">
            <h2>Histórico de notificações enviadas</h2>
            <span>Últimas comunicações realizadas.</span>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Funcionário</th>
                        <th>Canal</th>
                        <th>Mensagem</th>
                        <th>Data</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in HistoricoPaginado)
                    {
                        <tr>
                            <td>@item.FuncionarioId</td>
                            <td>@item.Canal</td>
                            <td>@item.Mensagem</td>
                            <td>
                                @(item.DataEnvio?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                            </td>
                        </tr>
                    }
                </tbody>
                @if (TotalPaginasHistorico > 1)
                {
                    <div class="pagination">
                        <button type="button" @onclick="PaginaAnteriorHistorico" disabled="@(PaginaAtualHistorico == 1)">
                            Anterior
                        </button>

                        <span>Página @PaginaAtualHistorico de @TotalPaginasHistorico</span>

                        <button type="button" @onclick="ProximaPaginaHistorico"
                                disabled="@(PaginaAtualHistorico >= TotalPaginasHistorico)">
                            Próxima
                        </button>
                    </div>
                }
            </table>

        </div>
    </section>
</div>

