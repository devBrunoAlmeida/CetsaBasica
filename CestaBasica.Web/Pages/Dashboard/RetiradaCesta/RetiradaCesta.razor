@page "/retiradas"

@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web


<div class="withdraw-page">

    <div class="page-header">
        <div>
            <h1>Registro de Retirada</h1>
            <p>Registre a entrega de cestas básicas por código de barras ou busca manual.</p>
        </div>
    </div>

    <section class="content-grid">

        <div class="panel">
            <div class="panel-header">
                <h2>Identificação do Funcionário</h2>
                <span>Informe o código de barras ou pesquise manualmente.</span>
            </div>

            <div class="form-group">
                <label>Código de barras</label>
                <input class="input-custom" placeholder="Leia ou digite o código de barras" value="@codigoBarras"
                       @oninput="BuscarPorCodigo" />
            </div>

            <div class="divider">
                <span>ou</span>
            </div>

            <div class="form-group">
                <label>Busca manual</label>
                <input class="input-custom" placeholder="Pesquisar por nome ou matrícula" value="@buscaManual"
                       @oninput="BuscarManual" />
            </div>

            @if (resultadosBusca.Any())
            {
                <div class="search-results">
                    @foreach (var item in resultadosBusca)
                    {
                        <button type="button" @onclick="() => SelecionarFuncionario(item)">
                            <strong>@item.NomeCompleto</strong>
                            <span>@item.Matricula • @item.Setor</span>
                        </button>
                    }
                </div>
            }
        </div>

        <div class="panel employee-card">
            <div class="panel-header">
                <h2>Dados do Funcionário</h2>
                <span>Informações carregadas automaticamente.</span>
            </div>

            @if (funcionarioSelecionado is not null)
            {
                <div class="employee-info">
                    <div class="avatar">
                        @funcionarioSelecionado.NomeCompleto[..1]
                    </div>

                    <div>
                        <h3>@funcionarioSelecionado.NomeCompleto</h3>
                        <p>@funcionarioSelecionado.Setor</p>
                    </div>
                </div>

                <div class="details-grid">
                    <div>
                        <span>Matrícula</span>
                        <strong>@funcionarioSelecionado.Matricula</strong>
                    </div>

                    <div>
                        <span>Código de barras</span>
                        <strong>@funcionarioSelecionado.CodigoBarras</strong>
                    </div>

                    <div>
                        <span>Telefone</span>
                        <strong>@funcionarioSelecionado.Telefone</strong>
                    </div>

                    <div>
                        <span>Status atual</span>
                        <strong class="status">@funcionarioSelecionado.Status</strong>
                    </div>
                </div>

                <div class="date-box">
                    <span>Data e hora do registro</span>
                    <strong>@DateTime.UtcNow.ToString("dd/MM/yyyy HH:mm")</strong>
                </div>

                <button type="button" class="btn-confirm" @onclick="ConfirmarRetirada">
                    Confirmar retirada
                </button>
            }
            else
            {
                <div class="empty-state">
                    <div>🔎</div>
                    <h3>Nenhum funcionário selecionado</h3>
                    <p>Faça a leitura do código de barras ou utilize a busca manual.</p>
                </div>
            }
        </div>

    </section>

    @if (retiradaConfirmada)
    {
        <div class="success-alert">
            ✅ Retirada registrada com sucesso para <strong>@ultimoFuncionario</strong>.
        </div>
    }

    <section class="history-panel">
        <div class="panel-header">
            <h2>Histórico recente de retiradas</h2>
            <span>Últimas entregas registradas no sistema.</span>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Funcionário</th>
                        <th>Matrícula</th>
                        <th>Setor</th>
                        <th>Status</th>
                        <th>Data da Retirada</th>
                    </tr>
                </thead>

                <tbody>
                    @if (historicoRetiradas.Any())
                    {
                        @foreach (var item in historicoRetiradas)
                        {
                            <tr>
                                <td>@item.NomeCompleto</td>
                                <td>@item.Matricula</td>
                                <td>@item.Setor</td>
                                <td><span class="badge">@item.Status</span></td>
                                <td>@item.DataRetirada.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="empty-table">
                                Nenhuma retirada recente encontrada.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

</div>