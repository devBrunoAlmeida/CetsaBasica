@page "/configuracoes"
@using CestaBasica.Shared.DTOs

<div class="settings-page">
    <div class="page-header">
        <div>
            <h1>Configurações do Sistema</h1>
            <p>Gerencie parâmetros operacionais, segurança, notificações e auditoria da plataforma.</p>
        </div>

        <button class="btn-primary"
                @onclick="SalvarConfiguracoes"
                disabled="@salvando">
            @(salvando ? "Salvando..." : "Salvar alterações")
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(mensagem))
    {
        <div class="alert-success">
            @mensagem
        </div>
    }

    <section class="settings-grid">

        <div class="settings-card">
            <div class="card-icon blue">🔔</div>
            <h2>Canais de Notificação</h2>
            <p>Configure os canais utilizados para comunicação com funcionários.</p>

            <label>
                <input type="checkbox" @bind="config.WhatsAppHabilitado" />
                WhatsApp habilitado
            </label>

            <label>
                <input type="checkbox" @bind="config.SmsHabilitado" />
                SMS habilitado
            </label>

            <label>
                <input type="checkbox" @bind="config.EnvioAutomaticoLembretes" />
                Envio automático de lembretes
            </label>
        </div>

        <div class="settings-card">
            <div class="card-icon yellow">⏱️</div>
            <h2>Configuração de Sessão</h2>
            <p>Defina regras de permanência e expiração de acesso.</p>

            <div class="form-group">
                <label>Tempo de sessão</label>
                <select @bind="config.TempoSessaoMinutos">
                    <option value="30">30 minutos</option>
                    <option value="60">1 hora</option>
                    <option value="120">2 horas</option>
                </select>
            </div>

            <label>
                <input type="checkbox" @bind="config.EncerrarPorInatividade" />
                Encerrar sessão por inatividade
            </label>
        </div>

        <div class="settings-card">
            <div class="card-icon green">💾</div>
            <h2>Backup</h2>
            <p>Configure rotinas de cópia de segurança dos dados do sistema.</p>

            <div class="form-group">
                <label>Frequência</label>
                <select @bind="config.FrequenciaBackup">
                    <option value="Diario">Diário</option>
                    <option value="Semanal">Semanal</option>
                    <option value="Mensal">Mensal</option>
                </select>
            </div>

            <button class="btn-secondary" type="button">
                Executar backup agora
            </button>
        </div>

        <div class="settings-card">
            <div class="card-icon purple">👥</div>
            <h2>Usuários</h2>
            <p>Defina políticas de acesso, perfis e permissões administrativas.</p>

            <label>
                <input type="checkbox" @bind="config.PermitirCadastroOperadores" />
                Permitir cadastro de operadores
            </label>
        </div>

        <div class="settings-card">
            <div class="card-icon red">🔐</div>
            <h2>Segurança</h2>
            <p>Gerencie regras de autenticação e proteção dos dados.</p>

            <label>
                <input type="checkbox" checked disabled />
                Autenticação segura
            </label>

            <label>
                <input type="checkbox" @bind="config.BloqueioTentativasInvalidas" />
                Bloqueio após tentativas inválidas
            </label>
        </div>

        <div class="settings-card logs-card">
            <div class="card-icon dark">📋</div>
            <h2>Logs do Sistema</h2>
            <p>Acompanhe eventos administrativos e ações críticas.</p>

            <div class="logs-list">
                <div>
                    <strong>Login administrativo</strong>
                    <span>16/05/2026 10:40</span>
                </div>

                <div>
                    <strong>Backup executado</strong>
                    <span>16/05/2026 09:00</span>
                </div>

                <div>
                    <strong>Usuário atualizado</strong>
                    <span>15/05/2026 17:25</span>
                </div>
            </div>
        </div>

    </section>
</div>